---
const title = "Portfolio under maintenance";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <style>
      :root {
        --bg: #0f172a;
        --text: #e2e8f0;
        --accent: #38bdf8;
      }

      body {
        margin: 0;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        background: var(--bg);
        color: var(--text);
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        text-align: center;
      }

      .container {
        max-width: 500px;
        padding: 2rem;
      }

      h1 {
        font-size: 2rem;
        margin-bottom: 1rem;
      }

      p {
        opacity: 0.8;
      }

      .dot {
        display: inline-block;
        width: 6px;
        height: 6px;
        background: var(--accent);
        border-radius: 50%;
        margin-left: 5px;
        animation: blink 1.4s infinite;
      }

      .dot:nth-child(2) {
        animation-delay: 0.2s;
      }
      .dot:nth-child(3) {
        animation-delay: 0.4s;
      }

      @keyframes blink {
        0%,
        80%,
        100% {
          opacity: 0;
        }
        40% {
          opacity: 1;
        }
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h1>
        🚧 Under maintenance
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </h1>

      <p>
        I'm currently working on improvements to the portfolio.<br />
        Check back soon 👀
      </p>
    </div>
  </body>
</html>

