---
import Layout from "../layouts/Layout.astro";
const title = "Portafolio en mantenimiento";
---

<Layout lang="es" title="Olver Arce | Portafolio">
  <div
    class="flex items-center justify-center min-h-screen bg-slate-900 text-slate-200 text-center"
  >
    <div class="max-w-md p-8">
      <h1 class="text-2xl mb-4">
        🚧 En mantenimiento
        <span
          class="inline-block w-1.5 h-1.5 bg-sky-400 rounded-full ml-1 animate-bounce [animation-delay:0s]"
        ></span>
        <span
          class="inline-block w-1.5 h-1.5 bg-sky-400 rounded-full ml-1 animate-bounce [animation-delay:0.2s]"
        ></span>
        <span
          class="inline-block w-1.5 h-1.5 bg-sky-400 rounded-full ml-1 animate-bounce [animation-delay:0.4s]"
        ></span>
      </h1>

      <p class="opacity-80">
        Estoy trabajando en mejoras para el portafolio.<br />
        Vuelve pronto 👀
      </p>
    </div>
  </div>
</Layout>
